{
  "name": "@batari/core-api",
  "version": "1.6.3",
  "description": "Batari Core API",
  "license": "UNLICENSED",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "build"
  ],
  "scripts": {
    "prepare": "husky install",
    "test": "jest --color --forceExit",
    "test:watch": "jest --watch --forceExit",
    "dev": "nodemon",
    "dev:infisical": "infisical run -- nodemon",
    "start": "node ./dist/src/index.js",
    "rollup": "rollup -c",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --quiet",
    "lint:fix": "eslint src --fix",
    "prettier:write": "prettier --write \"src/**/*.ts\"",
    "build": "rimraf ./dist && tsc --project tsconfig.json && tscpaths -p tsconfig.json -s ./src -o ./dist/src",
    "build:types": "rimraf ./build && rollup -c",
    "build:types:mobile": "rollup -c --file ../mobile-app/app/types/core-api.d.ts",
    "prestart": "npm run -s build",
    "openapi:types": "rimraf ./dist && pnpm build && api-extractor run --local",
    "openapi:conv": "typeconv -f ts -t oapi -o openapi --ts-declaration --no-hidden --ts-non-exported include openapi/components.d.ts",
    "openapi:swagger": "swagger-jsdoc -d swagger.js ./src/api/**/*.ts -o openapi/swagger.yaml",
    "openapi:redoc": "redocly build-docs openapi/swagger.yaml --output=openapi/index.html",
    "openapi:server": "open-cli openapi/index.html",
    "openapi": "rimraf openapi && mkdir openapi && pnpm openapi:types && pnpm openapi:conv && pnpm openapi:swagger && pnpm openapi:redoc && pnpm openapi:server",
    "prepublishOnly": "npm run build:types",
    "docker": "docker-compose up --build",
    "script": "ts-node --transpile-only -r dotenv/config src/scripts/migrate-iqamahCountdown.ts dotenv_config_path=./.env",
    "release:prerelease": "npm version prerelease && git push --follow-tags",
    "dev:staging": "infisical run --env=staging -- nodemon",
    "setup:master-data": "ts-node --transpile-only -r dotenv/config src/setup/index.ts dotenv_config_path=./.env"
  },
  "dependencies": {
    "amqp-connection-manager": "^4.1.14",
    "axios": "^1.3.5",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.4",
    "danfojs-node": "^1.1.2",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "firebase-admin": "^12.1.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.5",
    "lodash.clonedeep": "^4.5.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "mongodb": "^6.1.0",
    "mongoose": "^6.11.2",
    "mqtt": "^5.6.1",
    "multer": "^1.4.4",
    "nanoid": "^3.3.4",
    "node-cron": "^3.0.3",
    "node-mailjet": "^6.0.2",
    "redis": "^4.6.5",
    "redoc": "^2.1.2",
    "require-dir": "^1.2.0",
    "swagger-jsdoc": "^6.2.8",
    "typeconv": "^2.3.1",
    "uuid": "^9.0.1",
    "validator": "^13.9.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.6.1",
    "@commitlint/config-angular": "^17.6.1",
    "@jest/types": "^29.6.3",
    "@microsoft/api-extractor": "^7.38.0",
    "@redocly/cli": "^1.3.0",
    "@rollup/plugin-alias": "^5.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^9.0.2",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^8.0.7",
    "@semantic-release/npm": "^10.0.3",
    "@semantic-release/release-notes-generator": "^10.0.3",
    "@types/bcrypt": "^5.0.0",
    "@types/body-parser": "^1.19.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.18",
    "@types/express-serve-static-core": "^4.17.37",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/lodash": "^4.14.194",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/multer": "^1.4.7",
    "@types/node": "^18.15.11",
    "@types/node-cron": "^3.0.11",
    "@types/require-dir": "^1.0.2",
    "@types/uuid": "^9.0.4",
    "@types/validator": "^13.7.15",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^5.58.0",
    "@typescript-eslint/parser": "^5.58.0",
    "axios-mock-adapter": "^1.21.4",
    "conventional-changelog-angular": "^5.0.13",
    "conventional-changelog-eslint": "^3.0.9",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-eslint-plugin": "^5.0.8",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-import-order": "^2.1.4",
    "eslint-plugin-no-only-tests": "^3.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "lint-staged": "^13.2.1",
    "nodemon": "^2.0.22",
    "open-cli": "^7.2.0",
    "prettier": "^2.8.7",
    "rimraf": "^5.0.0",
    "rollup": "^2.75.7",
    "rollup-plugin-dts": "^4.2.2",
    "rollup-plugin-typescript": "^1.0.1",
    "semantic-release": "^21.0.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-prune": "^0.10.3",
    "tsc-alias": "^1.8.5",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-replace-paths": "^0.0.14",
    "tscpaths": "^0.0.9",
    "typescript": "^4.9.5",
    "typescript-transform-paths": "^3.4.6"
  }
}
